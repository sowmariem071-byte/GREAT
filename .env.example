DATABASE_URL="postgresql://content:content@localhost:5432/content_schedule?schema=public"
# Vercel/Supabase production can also provide one of these aliases; the app maps them to DATABASE_URL at runtime.
# In Vercel production, prefer the Supabase transaction pooler. The app also normalizes Supabase pooler URLs to port 6543 and adds pgbouncer=true, connection_limit=2, and pool_timeout=20.
# POSTGRES_PRISMA_URL="postgresql://..."
# POSTGRES_URL="postgresql://..."
# POSTGRES_URL_NON_POOLING="postgresql://..."
# SUPABASE_DATABASE_URL="postgresql://..."
# SUPABASE_DB_URL="postgresql://..."
# SUPABASE_POSTGRES_URL="postgresql://..."
# DATAASE_URL is only kept as a temporary compatibility alias for a previously mistyped Vercel variable.
# Prefer DATABASE_URL for all new production configuration.
# DATAASE_URL="postgresql://..."
SESSION_SECRET="replace-with-a-long-random-string"
APP_URL="http://localhost:3000"
COMPOSE_PROJECT_NAME="content-schedule"

# S3 compatible object storage. Works with AWS S3, Cloudflare R2, 阿里云 OSS S3 兼容网关, 腾讯 COS S3 兼容接口等。
S3_REGION="auto"
S3_ENDPOINT="https://example-account.r2.cloudflarestorage.com"
S3_BUCKET="content-schedule"
S3_ACCESS_KEY_ID="replace-me"
S3_SECRET_ACCESS_KEY="replace-me"
S3_PUBLIC_BASE_URL="https://cdn.example.com/content-schedule"
